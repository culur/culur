{
  "name": "@culur/monorepo",
  "version": "0.0.0",
  "description": "Culur's Monorepo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/culur/culur.git"
  },
  "bugs": {
    "url": "https://github.com/culur/culur/issues"
  },
  "homepage": "https://github.com/culur/culur#readme",
  "author": "culur <culur.net@gmail.com>",
  "license": "MIT",
  "workspaces": [
    "packages/**"
  ],
  "type": "module",
  "scripts": {
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "fix": "run-s 'fix:*'",
    "fix:md": "markdownlint **/*.md --fix",
    "fix:eslint": "eslint . --fix",
    "fix:prettier": "prettier . --write",
    "test": "run-s 'test:*'",
    "test:md": "markdownlint **/*.md",
    "test:eslint": "eslint .",
    "test:prettier": "prettier . --list-different",
    "test:spelling": "cspell '**'",
    "build": "tsx scripts/build.ts"
  },
  "engines": {
    "node": ">=16"
  },
  "volta": {
    "node": "16.16.0",
    "yarn": "1.22.19"
  },
  "packageManager": "yarn@3.2.3",
  "devDependencies": {
    "@changesets/cli": "^2.25.0",
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@culur/cli": "workspace:^",
    "@culur/config-prettier": "workspace:^",
    "@culur/config-typescript": "workspace:^",
    "@types/node": "^18.7.23",
    "chalk": "^5.0.1",
    "cspell": "^6.12.0",
    "eslint": "^8.24.0",
    "execa": "^6.1.0",
    "husky": "^8.0.1",
    "markdownlint-cli": "^0.32.2",
    "npm-run-all": "^4.1.5",
    "pinst": "^3.0.0",
    "prettier": "^2.7.1",
    "tsx": "^3.9.0",
    "typescript": "^4.8.4"
  }
}
