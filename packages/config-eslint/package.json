{
  "name": "@culur/config-eslint",
  "version": "1.8.0",
  "description": "Culur's eslint configuration",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/culur/culur.git",
    "directory": "packages/config-eslint"
  },
  "bugs": {
    "url": "https://github.com/culur/culur/issues"
  },
  "homepage": "https://github.com/culur/culur/tree/main/packages/config-eslint#readme",
  "author": "culur <culur.net@gmail.com>",
  "license": "MIT",
  "keywords": [
    "culur",
    "config",
    "eslint"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "!**/*.test.*",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist",
    "src"
  ],
  "scripts": {
    "clean": "rimraf dist coverage",
    "build": "tsdown",
    "test": "tsc --noEmit && vitest run"
  },
  "volta": {
    "extends": "../../package.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@culur/utils-packages": "workspace:*",
    "@vitest/eslint-plugin": "^1.6.13"
  },
  "devDependencies": {
    "@culur/config-tsdown": "workspace:*",
    "@culur/config-typescript": "workspace:*",
    "@eslint/eslintrc": "^3.3.5",
    "@types/eslint": "^9.6.1",
    "@vue/compiler-sfc": "^3.5.31",
    "eslint": "^10.1.0"
  },
  "peerDependencies": {
    "eslint": ">=10.0.0"
  }
}
