{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "lint": {
      "dependsOn": ["^build", "build"]
    },
    "test": {
      "dependsOn": ["^build", "build"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    },

    "build": {
      "outputs": ["dist"],
      "dependsOn": ["^build"]
    },
    "deploy": {
      "dependsOn": ["build"]
    }
  }
}
